# OpenAI MCP Research System Configuration

# Research Agent Configuration
OPENAI_API_KEY=sk-xxx                      # Get from https://platform.openai.com
NOTION_API_KEY=ntn_xxx                     # Get from https://www.notion.so/my-integrations
NOTION_DATABASE_ID=xxx                     # Your Notion database ID

# MCP Server Configuration
MCP_SERVER_URL=http://localhost:8000/sse   # Default local server endpoint
RAPID_API_KEY=xxx                          # Get from https://rapidapi.com (for Twitter API)
FIRECRAWL_API_KEY=xxx                      # Get from https://firecrawl.dev

# Optional: Email notifications (from reference project)
GMAIL_USER=your@email.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Optional: Alternative AI providers
GEMINI_API_KEY=xxx                         # Get from https://aistudio.google.com/app/apikey


# AWS S3 Compatible Storage (Railway Bucket)
# Used for persistent file storage in research_agent_cowork
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_ENDPOINT_URL=https://xxx.r2.cloudflarestorage.com  # or Railway bucket endpoint
AWS_S3_BUCKET_NAME=your-bucket-name

# Fluxa Payment Configuration
# Register at https://agentid.fluxapay.xyz/register to obtain credentials
FLUXA_AGENT_ID=                              # Agent ID from registration
FLUXA_AGENT_TOKEN=                           # OAuth-style secret token (for refreshing JWT)
FLUXA_AGENT_JWT=                             # JWT token for API authorization (auto-refreshed if expired)
FLUXA_PAY_TO_ADDRESS=                        # Your wallet address to receive payments (Base network)
FLUXA_NETWORK=base                           # Network: "base" (mainnet) or "base-sepolia" (testnet)
